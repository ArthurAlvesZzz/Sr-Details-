rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() { return request.auth != null; }
    
    function isAdminEmail() {
      return request.auth != null && request.auth.token.email == 'brgamexd@gmail.com';
    }

    function hasAdminRole(allowedRoles) {
      return isSignedIn() && exists(/databases/$(database)/documents/adminUsers/$(request.auth.uid)) && get(/databases/$(database)/documents/adminUsers/$(request.auth.uid)).data.role in allowedRoles;
    }

    function isOwner() {
      return isSignedIn() && (isAdminEmail() || hasAdminRole(['owner']));
    }
    
    function isManager() {
      return isSignedIn() && (isAdminEmail() || hasAdminRole(['owner', 'manager']));
    }
    
    function isAttendant() {
      return isSignedIn() && (isAdminEmail() || hasAdminRole(['owner', 'manager', 'attendant']));
    }
    
    function isTechnician() {
      return isSignedIn() && (isAdminEmail() || hasAdminRole(['owner', 'manager', 'attendant', 'technician']));
    }

    match /services/{docId} {
      allow read: if true;
      allow write: if isManager();
    }
    
    match /serviceCategories/{docId} {
      allow read: if true;
      allow write: if isManager();
    }
    
    match /businessSettings/{docId} {
      allow read: if true;
      allow write: if isOwner();
    }
    
    match /scheduleSettings/{docId} {
      allow read: if true;
      allow write: if isManager();
    }
    
    match /scannerRules/{docId} {
      allow read: if true;
      allow write: if isManager();
    }
    
    match /homeSections/{docId} {
      allow read: if true;
      allow write: if isManager();
    }

    match /bookings/{bookingId} {
      allow read: if true;
      allow create: if true;
      allow update: if isTechnician();
      allow delete: if isManager();
    }
    
    match /adminUsers/{userId} {
      allow read: if isSignedIn();
      allow write: if isOwner();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
